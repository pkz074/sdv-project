{
  mode: "router",
  listen: {
    endpoints: ["tcp/0.0.0.0:7447"]
  },
  plugins_loading: {
    enabled: true,
    search_dirs: ["/"]
  },
  plugins: {
    rest: {
      __required__: true,
      http_port: "8000"
    },
    storage_manager: {
      __required__: true,
      storages: {
        vehicle: {
          key_expr: "vehicle/**",
          volume: "memory"
        }
      }
    }
  }
}
